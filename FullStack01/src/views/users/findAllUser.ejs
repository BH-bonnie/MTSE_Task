<body>
    <table style="width: 100%;">
        <thead>
            <tr>
                <th>Email</th>
                <th>Password</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Address</th>
                <th>Gender</th>
                <th>Role ID</th>
                <th>Phone</th>
                <th>Avatar</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% for(let i=0; i < datalist.length; i++) { %>
                <tr>
                    <td>
                        <%= datalist[i].email %>
                    </td>
                    <td>
                        <%= datalist[i].password %>
                    </td>
                    <td>
                        <%= datalist[i].firstName %>
                    </td>
                    <td>
                        <%= datalist[i].lastName %>
                    </td>
                    <td>
                        <%= datalist[i].address %>
                    </td>
                    <td>
                        <%= datalist[i].gender %>
                    </td>
                    <td>
                        <%= datalist[i].roleId %>
                    </td>
                    <td>
                        <%= datalist[i].phone %>
                    </td>
                    <td>
                        <%= datalist[i].avatar %>
                    </td>
                    <td>
                        <a href="/edit-crud?id=<%= datalist[i].id %>">Edit</a>
                        |
                        <a href="/delete-crud?id=<%= datalist[i].id %>">Delete</a>
                    </td>
                </tr>
                <% } %>
        </tbody>
    </table>
</body>